<!DOCTYPE html>
<html lang='es'>
<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>Crypto Widget</title>
  <link rel='manifest' href='manifest.json' />
  <link rel='stylesheet' href='css/styles.css' />
  <script src='app.js' defer></script>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('service-worker.js');
    }
  </script>
</head>
<body>
  <h2 class='title'>Crypto Widget</h2>
  <div id='prices' class='card'></div>
  <button onclick='showChart()'>Ver Gráfico</button>
  <button onclick='showSignals()'>Panel de Señales</button>
  <div id='chartContainer' style='margin-top:20px; display:none;'>
    <script src='https://s3.tradingview.com/tv.js'></script>
    <div id='chart'></div>
  </div>
  <div id='signals' class='card' style='display:none;'></div>
</body>
</html>